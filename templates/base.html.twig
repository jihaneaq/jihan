{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Quiz Master{% endblock %}</title>
        
        {# Bootstrap 5 #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        {# FontAwesome pour des icônes professionnelles #}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

        <style>
            body { 
                background-color: #f4f7f6; 
                min-height: 100vh;
                display: flex;
                flex-direction: column;
            }
            .card { 
                border: none; 
                border-radius: 15px; 
                box-shadow: 0 4px 6px rgba(0,0,0,0.1); 
            }
            .navbar-brand {
                font-weight: bold;
                letter-spacing: 1px;
            }
            footer {
                margin-top: auto;
            }
        </style>
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        {# Barre de navigation #}
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_quiz_home') }}">
                    <i class="fas fa-lightbulb text-warning me-2"></i>QUIZ MASTER
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_quiz_home') }}">
                                <i class="fas fa-home me-1"></i> Accueil
                            </a>
                        </li>
                        
                        {# AFFICHAGE CONDITIONNEL SELON LA CONNEXION #}
                        {% if app.user %}
                            <li class="nav-item ms-lg-3">
                                <span class="text-light small me-2">
                                    <i class="fas fa-user-circle me-1"></i> {{ app.user.userIdentifier }}
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm" href="{{ path('app_logout') }}">
                                    <i class="fas fa-sign-out-alt"></i> Quitter
                                </a>
                            </li>
                        {% else %}
                            <li class="nav-item ms-lg-3">
                                <a class="btn btn-outline-light btn-sm" href="{{ path('app_login') }}">Connexion</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-warning btn-sm" href="{{ path('app_register') }}">S'inscrire</a>
                            </li>
                        {% endif %}

                        <li class="nav-item">
                            <a class="nav-link btn btn-primary btn-sm text-white ms-lg-3 px-3" href="{{ path('quiz_index') }}">
                                <i class="fas fa-play-circle me-1"></i> Jouer
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        {# Contenu principal #}
        <div class="container py-4">
            {% block body %}{% endblock %}
        </div>

        {# Pied de page #}
        <footer class="bg-white border-top py-3 mt-5">
            <div class="container text-center text-muted">
                <small>&copy; 2024 Quiz Master Symfony - Projet Étudiant</small>
            </div>
        </footer>

        {# Scripts Bootstrap #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>